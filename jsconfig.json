{
  "compilerOptions": {
    "baseUrl": "./src",
    "paths": {
      "@/*": ["./*"],
      "@components/*": ["./components/*"],
      "@pages/*": ["./pages/*"],
      "@hooks/*": ["./hooks/*"],
      "@utils/*": ["./utils/*"],
      "@constants/*": ["./constants/*"],
      "@styles/*": ["./styles/*"],
      "@context/*": ["./context/*"],
      "@assets/*": ["./assets/*"]
    },
    "jsx": "react-jsx"
  }
}
